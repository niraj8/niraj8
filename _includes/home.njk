{% extends "base.njk" %}
{% block extraHead %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@1,100&display=swap" rel="stylesheet">
{% endblock %}
{% block body %}
  <h1 style="text-align:center;font-size:3.5em;font-family:'Roboto',sans-serif;font-style:italic !important;font-weight:100;">Niraj Palecha</h1>
  {{ content | safe }}
  {% include "nav.njk" %}
  <div style="text-align:center;margin:2rem 0;">
    <img src="images/Landour Bakehouse Delivery Van.jpeg" alt="Broken down car with text on the side 'We'll start delivery as soon as our vehicles are fixed'" style="width:auto;max-height:50%;display:block;margin:0 auto;"/>
  </div>
{% endblock %}
